# ============================================
# BCI Research Toolkit — 环境变量配置
# 复制此文件为 .env 并填入你的 API key
# ============================================

# ============================================
# DeepSeek API（主力推荐，¥2/1M tokens，性价比最高）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 默认使用 DeepSeek（避免每次指定 --model）
AO_DEFAULT_PROVIDER=deepseek
AO_DEFAULT_MODEL=deepseek-chat

# Claude Code 接入 DeepSeek（让 Claude Code 底层也用 DeepSeek）
# 取消下面两行的注释，Claude Code 就会走 DeepSeek 免费用
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_API_KEY=sk-your-deepseek-key-here

# 智谱 GLM API（备用，高校常有免费额度）
# 获取地址：https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=your-glm-key-here

# ============================================
# 以下可选——如果你有这些会员，可以不花额外钱
# ============================================

# Claude API（如果你用 Claude Code，本机已登录则可跳过）
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API（备用）
# OPENAI_API_KEY=sk-your-key-here

# ============================================
# 自定义目录（可选）
# ============================================

# 输出目录（默认 ./ao-output/）
# AO_OUTPUT_DIR=./output

# 自定义角色库（默认使用内置角色）
# AO_AGENTS_DIR=./agents

# 统一工作区（所有产物集中管理）
# AO_HOME=~/.ao
